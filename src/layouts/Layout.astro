---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Cart from '../components/Cart.astro';
import SeoHead from '../components/seo/SeoHead.astro';
import '../styles/global.css';
import '../styles/admin.css';

export interface Props {
	/** Sin margen superior del footer (p. ej. inicio con CTA oscuro pegado al pie). */
	footerFlushTop?: boolean;
	title: string;
	description: string;
	keywords?: string;
	/** No indexar (p. ej. panel admin). */
	noindex?: boolean;
	/** Imagen Open Graph bajo /public (p. ej. /Logo.png). */
	ogImagePath?: string;
}

const {
	footerFlushTop = false,
	title,
	description,
	keywords,
	noindex = false,
	ogImagePath,
} = Astro.props;

const canonicalBase = Astro.site ?? new URL('https://www.hydraulicsistem.com');
const canonicalUrl = new URL(Astro.url.pathname, canonicalBase).href;
---
<!doctype html>
<html lang="es-BO">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" type="image/png" href="/Logo.png" />
		<link rel="apple-touch-icon" href="/Logo.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<SeoHead
			title={title}
			description={description}
			keywords={keywords}
			canonicalUrl={canonicalUrl}
			noindex={noindex}
			ogImagePath={ogImagePath}
		/>
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer flushTop={footerFlushTop} />
		<Cart phoneNumber="59170405030" />
	</body>
</html>

<style is:global>
	html {
		height: 100%;
	}

	body {
		margin: 0;
		width: 100%;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	main {
		flex: 1;
	}
</style>
