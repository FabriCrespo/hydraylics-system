---
import { Cog } from "@lucide/astro/icons";

export interface Props {
	/** Elimina el margen superior respecto al contenido (útil en la home). */
	flushTop?: boolean;
}

const { flushTop = false } = Astro.props;
const year = new Date().getFullYear();

const mainLinks = [
  { href: "/", label: "Inicio" },
  { href: "/servicios", label: "Servicios" },
  { href: "/productos", label: "Productos" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/contacto", label: "Contacto" },
] as const;
---

<footer
  class:list={[
    "relative overflow-hidden bg-[#14100f] font-[Inter,ui-sans-serif,system-ui,sans-serif] text-white/75",
    flushTop ? "mt-0" : "mt-[clamp(3rem,8vw,5rem)]",
  ]}
>
  <!-- Acento superior en la misma familia cromática que los CTAs del hero -->
  <div
    class="pointer-events-none absolute inset-x-0 top-0 z-0 h-px bg-[linear-gradient(90deg,transparent_0%,rgba(122,21,18,0.85)_45%,rgba(122,21,18,0.85)_55%,transparent_100%)]"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 z-0 h-32 bg-[linear-gradient(180deg,rgba(122,21,18,0.12)_0%,transparent_100%)]"
    aria-hidden="true"
  >
  </div>
  <div
    class="relative z-[1] mx-auto w-full max-w-[1200px] px-[clamp(1.5rem,4vw,2.5rem)] py-[clamp(2.5rem,5vw,3.75rem)] max-[968px]:px-4"
  >
    <div
      class="flex flex-col gap-10 max-[968px]:gap-8 lg:flex-row lg:items-end lg:justify-between lg:gap-12"
    >
      <a
        href="/"
        class="group flex shrink-0 items-start gap-3 no-underline focus-visible:rounded focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#7a1512] lg:max-w-[min(100%,20rem)]"
        aria-label="Hydraulic Sistem — Inicio"
      >
        <span
          class="mt-0.5 flex size-10 shrink-0 items-center justify-center rounded border border-white/10 bg-[#7a1512]/25 text-[#e8a8a3]"
          aria-hidden="true"
        >
          <Cog class="size-5" aria-hidden="true" />
        </span>
        <span class="min-w-0">
          <span
            class="block text-[clamp(0.7rem,1.5vw,0.8rem)] font-extrabold uppercase leading-[1.15] tracking-[0.04em] text-white transition-colors group-hover:text-white/95"
          >
            Hydraulic Sistem
          </span>
          <span
            class="mt-1 block text-[clamp(0.68rem,1.4vw,0.78rem)] font-semibold uppercase leading-snug tracking-[0.06em] text-white/80 transition-colors group-hover:text-white/90"
          >
            Ingeniería de precisión
          </span>
        </span>
      </a>

      <nav
        class="flex min-w-0 flex-col gap-4 lg:flex-1 lg:items-center"
        aria-label="Enlaces del sitio"
      >
        <ul
          class="m-0 flex list-none flex-wrap gap-x-5 gap-y-2.5 p-0 max-[640px]:flex-col max-[640px]:gap-2 sm:gap-x-6 lg:w-full lg:flex-wrap lg:justify-center lg:gap-x-6"
        >
          {
            mainLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="inline-flex text-[0.8rem] font-semibold uppercase tracking-[0.06em] text-white/70 no-underline transition duration-300 hover:text-white max-[640px]:py-1"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div
        class="w-full border-t border-white/10 pt-6 text-[0.8rem] leading-relaxed text-white/55 max-[968px]:text-left lg:w-auto lg:max-w-[16rem] lg:border-t-0 lg:pt-0 lg:text-right"
      >
        <p class="m-0">
          © {year} Hydraulic Sistem. Todos los derechos
        </p>
        <p class="m-0">reservados.</p>
      </div>
    </div>
  </div>
</footer>
