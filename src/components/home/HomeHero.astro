<section
  class="relative flex min-h-[90vh] items-center justify-start overflow-hidden bg-[url('/home/hero.jpg')] bg-cover bg-center bg-no-repeat max-[640px]:min-h-[80vh]"
>
  <div
    class="pointer-events-none absolute inset-0 z-0 bg-[linear-gradient(90deg,rgba(20,16,15,0.88)_0%,rgba(20,16,15,0.55)_38%,rgba(20,16,15,0.2)_62%,transparent_85%)]"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-0 z-[1] bg-[linear-gradient(180deg,rgba(0,0,0,0.15)_0%,transparent_40%,rgba(0,0,0,0.25)_100%)]"
    aria-hidden="true"
  >
  </div>
  <div
    id="hero-content"
    class="relative z-[2] mx-auto w-full max-w-[1200px] px-[clamp(1.5rem,4vw,2.5rem)] py-[clamp(2rem,5vw,4rem)] will-change-transform max-[968px]:px-4 max-[968px]:py-5"
  >
    <div class="max-w-[34rem] text-left max-[968px]:max-w-full">
      <div class="w-full">
        <h1
          class="mb-5 text-[clamp(1.75rem,4.2vw,3.15rem)] font-extrabold uppercase leading-[1.12] tracking-[0.04em] text-white max-[640px]:text-[2rem]"
        >
          Potencia hidráulica que mueve tu mundo
        </h1>
        <p
          class="mb-8 max-w-[32rem] text-[clamp(1rem,1.35vw,1.2rem)] font-normal leading-[1.65] text-white/95"
        >
          Expertos en reparación y mantenimiento de maquinaria pesada.
          Ingeniería de precisión para mantener tu operación en movimiento
          constante.
        </p>
        <div
          class="flex flex-wrap items-center gap-x-4 gap-y-[0.85rem] max-[640px]:w-full max-[640px]:flex-col"
        >
          <a
            href="#contacto"
            class="inline-flex items-center justify-center rounded px-7 py-[0.95rem] text-[0.8rem] font-semibold uppercase tracking-[0.06em] text-white shadow-none transition duration-300 [background-color:#7a1512] hover:[background-color:#5c0f0d] hover:text-white max-[640px]:w-full max-[640px]:justify-center hover:-translate-y-0.5 hover:scale-[1.02]"
            >Solicitar servicio</a
          >
          <a
            href="/productos"
            class="inline-flex items-center justify-center rounded border-2 border-white/95 bg-transparent px-7 py-[0.95rem] text-[0.8rem] font-semibold uppercase tracking-[0.06em] text-white transition duration-300 hover:border-white hover:bg-white/12 hover:text-white max-[640px]:w-full max-[640px]:justify-center hover:-translate-y-0.5 hover:scale-[1.02]"
            >Nuestros productos</a
          >
        </div>
      </div>
    </div>
  </div>
  <div
    class="absolute bottom-[30px] left-1/2 z-[3] -translate-x-1/2 max-[968px]:bottom-8"
    aria-hidden="true"
  >
    <span
      class="relative block h-[50px] w-[30px] rounded-[50px] border-2 border-white/85 before:absolute before:left-1/2 before:top-2.5 before:h-1.5 before:w-1.5 before:-translate-x-1/2 before:rounded-full before:bg-white before:content-[''] before:animate-[home-scroll_2s_infinite]"
    ></span>
  </div>
</section>
