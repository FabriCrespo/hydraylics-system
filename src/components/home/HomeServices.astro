---
import { Cpu, GitBranch, Headphones, Layers } from "@lucide/astro/icons";
---

<section id="servicios" class="bg-gray-50 py-20 md:py-24">
  <div class="mx-auto max-w-[1200px] px-6 sm:px-8">
    <header class="mb-12 text-center md:mb-16">
      <p
        class="text-xs font-bold uppercase tracking-[0.2em] text-secondary sm:text-sm"
      >
        Especialización técnica
      </p>
      <h2
        class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl"
      >
        Soluciones en Ingeniería Hidráulica
      </h2>
    </header>

    <div
      class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8"
    >
      <article
        class="group flex h-full flex-col border border-gray-100 bg-white p-8 text-left shadow-sm transition-shadow duration-300 hover:shadow-md"
      >
        <div
          class="mb-6 flex h-12 w-12 shrink-0 items-center justify-center bg-gray-100 text-gray-900"
          aria-hidden="true"
        >
          <Layers class="size-6 stroke-[2] stroke-current" />
        </div>
        <h3 class="mb-4 text-xl font-bold text-gray-900">Cilindros Hidráulicos</h3>
        <p class="mb-8 flex-1 text-base leading-relaxed text-gray-600">
          Reparación, fabricación y sellado de cilindros de alta presión para
          minería y construcción.
        </p>
        <a
          href="/servicios"
          class="mt-auto inline-flex items-center gap-1 text-sm font-bold uppercase tracking-wide text-secondary transition-[gap] duration-200 hover:gap-2"
        >
          Detalles <span aria-hidden="true">→</span>
        </a>
      </article>

      <article
        class="group flex h-full flex-col border border-gray-100 bg-white p-8 text-left shadow-sm transition-shadow duration-300 hover:shadow-md"
      >
        <div
          class="mb-6 flex h-12 w-12 shrink-0 items-center justify-center bg-gray-100 text-gray-900"
          aria-hidden="true"
        >
          <Cpu class="size-6 stroke-[2] stroke-current" />
        </div>
        <h3 class="mb-4 text-xl font-bold text-gray-900">Bombas y Motores</h3>
        <p class="mb-8 flex-1 text-base leading-relaxed text-gray-600">
          Diagnóstico computarizado y reconstrucción de bombas de pistones y
          motores hidráulicos.
        </p>
        <a
          href="/servicios"
          class="mt-auto inline-flex items-center gap-1 text-sm font-bold uppercase tracking-wide text-secondary transition-[gap] duration-200 hover:gap-2"
        >
          Detalles <span aria-hidden="true">→</span>
        </a>
      </article>

      <article
        class="group flex h-full flex-col border border-gray-100 bg-white p-8 text-left shadow-sm transition-shadow duration-300 hover:shadow-md"
      >
        <div
          class="mb-6 flex h-12 w-12 shrink-0 items-center justify-center bg-gray-100 text-gray-900"
          aria-hidden="true"
        >
          <GitBranch class="size-6 stroke-[2] stroke-current" />
        </div>
        <h3 class="mb-4 text-xl font-bold text-gray-900">Válvulas y Mandos</h3>
        <p class="mb-8 flex-1 text-base leading-relaxed text-gray-600">
          Calibración de bancos de válvulas y sistemas de control proporcional
          para precisión extrema.
        </p>
        <a
          href="/servicios"
          class="mt-auto inline-flex items-center gap-1 text-sm font-bold uppercase tracking-wide text-secondary transition-[gap] duration-200 hover:gap-2"
        >
          Detalles <span aria-hidden="true">→</span>
        </a>
      </article>

      <article
        class="group flex h-full flex-col border border-gray-100 bg-white p-8 text-left shadow-sm transition-shadow duration-300 hover:shadow-md"
      >
        <div
          class="mb-6 flex h-12 w-12 shrink-0 items-center justify-center bg-gray-100 text-gray-900"
          aria-hidden="true"
        >
          <Headphones class="size-6 stroke-[2] stroke-current" />
        </div>
        <h3 class="mb-4 text-xl font-bold text-gray-900">Servicio 24/7</h3>
        <p class="mb-8 flex-1 text-base leading-relaxed text-gray-600">
          Asistencia técnica en sitio y atención de emergencias para evitar
          paradas críticas.
        </p>
        <a
          href="/servicios"
          class="mt-auto inline-flex items-center gap-1 text-sm font-bold uppercase tracking-wide text-secondary transition-[gap] duration-200 hover:gap-2"
        >
          Detalles <span aria-hidden="true">→</span>
        </a>
      </article>
    </div>
  </div>
</section>
