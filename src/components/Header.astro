---
import { CircleUser, ShoppingCart } from "@lucide/astro/icons";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

function navActive(href: string) {
  const h = href.replace(/\/$/, "") || "/";
  if (h === "/") return pathname === "/";
  return pathname === h || pathname.startsWith(`${h}/`);
}

const contactActive = pathname === "/contacto" || pathname.startsWith("/contacto/");
---

<header
  class="sticky top-0 z-1000 overflow-visible border-b border-[#E8E8E8] bg-white/90 shadow-[0_1px_2px_rgba(0,0,0,0.05)] backdrop-blur-[6px] supports-backdrop-filter:bg-white/85"
>
  <div
    class="relative mx-auto flex max-w-[1280px] min-h-20 items-center justify-between gap-4 overflow-visible px-6 py-3 font-[Inter,ui-sans-serif,system-ui,sans-serif] max-md:min-h-0 max-md:gap-3 max-md:px-3 max-md:py-2.5"
  >
    <div class="relative z-2 flex shrink-0 items-center overflow-visible">
      <a
        href="/"
        class="flex items-center leading-none no-underline focus-visible:rounded focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#C60D00]"
        aria-label="Hydraulic Sistem — Inicio"
      >
        <!-- Caja de layout baja + scale: logo más grande sin subir min-h del header -->
        <img
          src="/HeroLogo.png"
          alt=""
          class="block h-8 w-auto max-w-[100px] origin-left scale-[2.15] object-contain object-left transition-[transform,opacity] duration-200 ease-out hover:scale-[2.24] hover:opacity-90 min-[900px]:h-[2.125rem] min-[900px]:max-w-[110px] min-[900px]:scale-[2.35] min-[900px]:hover:scale-[2.42] xl:h-9 xl:max-w-[118px] xl:scale-[2.45] xl:hover:scale-[2.52] max-md:h-7 max-md:max-w-[78px] max-md:scale-[2.05] max-md:hover:scale-[2.12]"
          width="400"
          height="90"
          loading="eager"
          decoding="async"
        />
      </a>
    </div>

    <nav
      id="site-nav"
      class="isolate z-50 min-w-0 max-md:pointer-events-none max-md:absolute max-md:left-0 max-md:right-0 max-md:top-full max-md:border-t max-md:border-[#E8E8E8] max-md:bg-white/95 max-md:shadow-md max-md:backdrop-blur-md max-md:transition-all max-md:duration-200 max-md:data-[state=closed]:max-h-0 max-md:data-[state=closed]:-translate-y-px max-md:data-[state=closed]:overflow-hidden max-md:data-[state=closed]:opacity-0 max-md:data-[state=closed]:py-0 max-md:data-[state=open]:pointer-events-auto max-md:data-[state=open]:max-h-[min(520px,85vh)] max-md:data-[state=open]:translate-y-0 max-md:data-[state=open]:opacity-100 max-md:data-[state=open]:overflow-y-auto max-md:data-[state=open]:py-3 md:relative md:top-auto md:flex md:flex-1 md:justify-center md:overflow-visible md:opacity-100 md:transition-none"
      data-state="closed"
      aria-label="Principal"
    >
      <ul
        class="m-0 flex list-none flex-col gap-0 p-0 md:flex-row md:items-center md:gap-8"
      >
        <li>
          <a
            href="/"
            class:list={[
              "relative isolate flex flex-col items-start py-1 text-[14px] font-normal uppercase leading-5 tracking-[-0.35px] no-underline transition-colors after:pointer-events-none max-md:block max-md:border-b max-md:border-[#E8E8E8] max-md:px-5 max-md:py-3 max-md:text-[0.9rem] max-md:hover:bg-[#f9f9f9]",
              navActive("/")
                ? "text-[#1A1C1C] after:absolute after:inset-x-0 after:-bottom-1 after:h-0.5 after:bg-[#C60D00] max-md:after:hidden"
                : "text-[#5F5E5E] after:hidden hover:text-[#1A1C1C]",
            ]}
            aria-current={navActive("/") ? "page" : undefined}>Inicio</a>
        </li>
        <li>
          <a
            href="/servicios"
            class:list={[
              "relative isolate flex flex-col items-start py-1 text-[14px] font-normal uppercase leading-5 tracking-[-0.35px] no-underline transition-colors after:pointer-events-none max-md:block max-md:border-b max-md:border-[#E8E8E8] max-md:px-5 max-md:py-3 max-md:text-[0.9rem] max-md:hover:bg-[#f9f9f9]",
              navActive("/servicios")
                ? "text-[#1A1C1C] after:absolute after:inset-x-0 after:-bottom-1 after:h-0.5 after:bg-[#C60D00] max-md:after:hidden"
                : "text-[#5F5E5E] after:hidden hover:text-[#1A1C1C]",
            ]}
            aria-current={navActive("/servicios") ? "page" : undefined}
            >Servicios</a>
        </li>
        <li>
          <a
            href="/productos"
            class:list={[
              "relative isolate flex flex-col items-start py-1 text-[14px] font-normal uppercase leading-5 tracking-[-0.35px] no-underline transition-colors after:pointer-events-none max-md:block max-md:border-b max-md:border-[#E8E8E8] max-md:px-5 max-md:py-3 max-md:text-[0.9rem] max-md:hover:bg-[#f9f9f9]",
              navActive("/productos")
                ? "text-[#1A1C1C] after:absolute after:inset-x-0 after:-bottom-1 after:h-0.5 after:bg-[#C60D00] max-md:after:hidden"
                : "text-[#5F5E5E] after:hidden hover:text-[#1A1C1C]",
            ]}
            aria-current={navActive("/productos") ? "page" : undefined}
            >Productos</a>
        </li>
        <li>
          <a
            href="/nosotros"
            class:list={[
              "relative isolate flex flex-col items-start py-1 text-[14px] font-normal uppercase leading-5 tracking-[-0.35px] no-underline transition-colors after:pointer-events-none max-md:block max-md:border-b max-md:border-[#E8E8E8] max-md:px-5 max-md:py-3 max-md:text-[0.9rem] max-md:hover:bg-[#f9f9f9]",
              navActive("/nosotros")
                ? "text-[#1A1C1C] after:absolute after:inset-x-0 after:-bottom-1 after:h-0.5 after:bg-[#C60D00] max-md:after:hidden"
                : "text-[#5F5E5E] after:hidden hover:text-[#1A1C1C]",
            ]}
            aria-current={navActive("/nosotros") ? "page" : undefined}
            >Nosotros</a>
        </li>
        <li class="md:hidden">
          <a
            href="/contacto"
            class="mx-5 my-3 block rounded-[2px] bg-[#C60D00] px-8 py-2.5 text-center text-sm font-normal uppercase tracking-[1.4px] text-white no-underline shadow-[0px_4px_6px_-1px_rgba(0,0,0,0.1),0px_2px_4px_-2px_rgba(0,0,0,0.1)] transition-opacity hover:opacity-90"
            aria-current={contactActive ? "page" : undefined}>Contacto</a>
        </li>
      </ul>
    </nav>

    <div
      class="hidden h-8 w-px shrink-0 bg-[#E7BDB6] md:block"
      aria-hidden="true"
    >
    </div>

    <div
      class="flex shrink-0 items-center gap-4 max-md:order-3 max-md:ml-auto max-md:gap-2 md:ml-0 md:gap-4"
    >
      <a
        href="/admin"
        class="inline-flex size-9 items-center justify-center rounded-xl bg-transparent p-2 text-[#5F5E5E] no-underline transition-colors hover:bg-black/4 hover:text-[#1A1C1C] [&_svg]:size-5"
        aria-label="Panel de Administración"
        title="Administración"
      >
        <CircleUser aria-hidden="true" />
      </a>
      <button
        class="relative inline-flex size-9 items-center justify-center rounded-xl border-none bg-transparent p-2 text-[#5F5E5E] transition-colors hover:bg-black/4 hover:text-[#1A1C1C] [&_svg]:size-5"
        type="button"
        aria-label="Ver carrito"
      >
        <ShoppingCart aria-hidden="true" />
        <span
          class="absolute -right-0.5 top-0 hidden min-h-[23px] min-w-[22px] items-center justify-center rounded-xl border-2 border-white bg-[#C60D00] px-1.5 py-0.5 text-center text-[10px] font-bold leading-[15px] text-white empty:hidden"
          id="cartCount"
          aria-live="polite"
        ></span>
      </button>
    </div>

    <a
      href="/contacto"
      class:list={[
        "hidden shrink-0 items-center justify-center rounded-[2px] bg-[#C60D00] px-8 py-2.5 text-sm font-normal uppercase tracking-[1.4px] text-white no-underline shadow-[0px_4px_6px_-1px_rgba(0,0,0,0.1),0px_2px_4px_-2px_rgba(0,0,0,0.1)] transition-opacity hover:opacity-90 md:inline-flex",
        contactActive &&
          "ring-2 ring-[#1A1C1C]/15 ring-offset-2 ring-offset-white/80",
      ]}
      aria-current={contactActive ? "page" : undefined}>Contacto</a>

    <button
      id="site-menu-toggle"
      type="button"
      class="group/menu relative z-1001 hidden cursor-pointer flex-col border-none bg-transparent p-1.5 text-[#5F5E5E] max-md:flex"
      aria-label="Abrir o cerrar menú"
      aria-controls="site-nav"
      aria-expanded="false"
      data-menu="closed"
    >
      <span
        class="my-0.5 block h-0.5 w-[22px] rounded-sm bg-current transition-all duration-300 group-data-[menu=open]/menu:translate-y-2 group-data-[menu=open]/menu:rotate-45"
      ></span>
      <span
        class="my-0.5 block h-0.5 w-[22px] rounded-sm bg-current transition-all duration-300 group-data-[menu=open]/menu:-translate-x-2.5 group-data-[menu=open]/menu:opacity-0"
      ></span>
      <span
        class="my-0.5 block h-0.5 w-[22px] rounded-sm bg-current transition-all duration-300 group-data-[menu=open]/menu:-translate-y-2 group-data-[menu=open]/menu:-rotate-45"
      ></span>
    </button>
  </div>
</header>

<script>
  const menuToggle = document.querySelector("#site-menu-toggle");
  const nav = document.querySelector("#site-nav");

  function setMenuOpen(open: boolean) {
    if (!menuToggle || !nav) return;
    nav.setAttribute("data-state", open ? "open" : "closed");
    menuToggle.setAttribute("data-menu", open ? "open" : "closed");
    menuToggle.setAttribute("aria-expanded", open ? "true" : "false");
  }

  if (menuToggle && nav) {
    menuToggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = nav.getAttribute("data-state") !== "open";
      setMenuOpen(open);
    });

    nav.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setMenuOpen(false));
    });

    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      if (!menuToggle.contains(target) && !nav.contains(target)) {
        setMenuOpen(false);
      }
    });
  }
</script>
