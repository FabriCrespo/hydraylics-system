---
import { ChevronLeft, ChevronRight } from "@lucide/astro/icons";
import { pc } from "../data/productCardTailwind";

interface Props {
  producto: {
    id: string;
    nombre: string;
    descripcion?: string;
    imagen?: string | string[];
    modelos_compatibles?: string[];
  };
}

/** Orden de prioridad alineado con `extraerMarcas` en productos.astro */
const MARCAS_CONOCIDAS = [
  "KAWASAKI",
  "REXROTH",
  "CATERPILLAR",
  "SAUER SUNDSTRAND",
  "SAUER",
  "SUNDSTRAND",
  "LINDE",
  "KOMATSU",
  "VICKERS",
  "EATON",
  "PARKER",
  "HITACHI",
  "MEDAL",
  "MOTOCANA",
] as const;

function etiquetaMarca(producto: Props["producto"]): string {
  const pool = [
    producto.nombre ?? "",
    producto.descripcion ?? "",
    ...(producto.modelos_compatibles ?? []),
  ]
    .join(" ")
    .toUpperCase();
  if (pool.includes("PARKER HANNIFIN") || pool.includes("PARKER")) {
    return "PARKER";
  }
  for (const m of MARCAS_CONOCIDAS) {
    if (pool.includes(m)) return m;
  }
  return "HYDRAULIC SISTEM";
}

const { producto } = Astro.props;
const marcaEtiqueta = etiquetaMarca(producto);
const modelos = producto.modelos_compatibles ?? [];
const imagenes = producto.imagen
  ? Array.isArray(producto.imagen)
    ? producto.imagen
    : [producto.imagen]
  : ["/placeholder-producto.jpg"];
const tieneImagen = imagenes.length > 0 && imagenes[0] !== "/placeholder-producto.jpg";
const tieneMultiplesImagenes = imagenes.length > 1;
---

<div
  class={pc.card}
  data-modelos={modelos.join(",")}
  data-imagen={tieneImagen ? "true" : "false"}
>
  <div class={pc.imagenWrap}>
    <div class={pc.imgContainer}>
      {
        imagenes.map((img, index) => (
          <img
            src={img}
            alt={`${producto.nombre} - Imagen ${index + 1}`}
            loading="lazy"
            class:list={[pc.img, index === 0 && "active"]}
            data-image-index={index}
          />
        ))
      }
    </div>
    {
      tieneMultiplesImagenes && (
        <>
          <button
            class={pc.navPrev}
            type="button"
            aria-label="Imagen anterior"
            data-producto-id={producto.id}
          >
            <ChevronLeft size={16} aria-hidden="true" />
          </button>
          <button
            class={pc.navNext}
            type="button"
            aria-label="Imagen siguiente"
            data-producto-id={producto.id}
          >
            <ChevronRight size={16} aria-hidden="true" />
          </button>
          <div class={pc.indicators}>
            {imagenes.map((_, index) => (
              <button
                class:list={[pc.indicator, index === 0 && "active"]}
                type="button"
                aria-label={`Ver imagen ${index + 1}`}
                data-image-index={index}
                data-producto-id={producto.id}
              />
            ))}
          </div>
        </>
      )
    }
  </div>

  <div class={pc.info}>
    <p class={pc.marca}>{marcaEtiqueta}</p>
    <h4 class={pc.nombre}>{producto.nombre}</h4>
    <p class={pc.descripcion}>{producto.descripcion}</p>
    {
      modelos.length > 0 && (
        <p class={pc.compat}>
          Ref. {modelos.slice(0, 4).join(" · ")}
          {modelos.length > 4 ? "…" : ""}
        </p>
      )
    }

    <div class={pc.precioRow}>
      <div class={pc.precioBloque}>
        <span class={pc.precio}>Consultar</span>
        <span class={pc.precioMeta}>precio</span>
      </div>
      <button
        class={pc.infoBtn}
        type="button"
        aria-label={`Ver detalles de ${producto.nombre}`}
        data-producto-id={producto.id}
      >
        Ver detalles
      </button>
    </div>

    <div class={pc.cantidadFila}>
      <span class={pc.cantidadLabel}>Cantidad</span>
      <div class={pc.cantidadControl} data-producto-id={producto.id}>
        <button
          class={pc.cantidadBtn}
          type="button"
          data-action="decremento"
          aria-label="Disminuir cantidad"
        >
          &minus;
        </button>
        <input
          class={pc.cantidadInput}
          type="number"
          min="1"
          step="1"
          value="1"
          inputmode="numeric"
          aria-label="Cantidad"
        />
        <button
          class={pc.cantidadBtn}
          type="button"
          data-action="incremento"
          aria-label="Aumentar cantidad"
        >
          +
        </button>
      </div>
    </div>

    <div class={pc.actions}>
      <button class={pc.btnCarrito} type="button" data-producto-id={producto.id}>
        Añadir al carrito
      </button>
    </div>
  </div>
</div>
