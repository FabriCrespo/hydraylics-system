---
import { Check, Wrench, Zap } from "@lucide/astro/icons";
import { nosotrosWhyItems } from "../../data/nosotrosWhyUs";
---

<section class="bg-white py-14 sm:py-16 md:py-24" aria-labelledby="nosotros-why-heading">
  <div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
    <div
      class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16 xl:gap-20"
    >
      <div>
        <p
          class="mb-3 inline-block rounded-none border border-secondary/30 bg-secondary/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-secondary sm:text-sm"
        >
          La diferencia Hydraulic Sistem
        </p>
        <h2
          id="nosotros-why-heading"
          class="text-balance text-[clamp(1.65rem,3.5vw,2.5rem)] font-extrabold leading-tight text-tertiary"
        >
          Por qué somos tu mejor opción
        </h2>
        <ul class="mt-8 flex list-none flex-col gap-5 p-0 sm:mt-10 sm:gap-6">
          {
            nosotrosWhyItems.map((row) => (
              <li class="flex gap-4">
                <span
                  class="mt-0.5 flex size-8 shrink-0 items-center justify-center bg-secondary text-sm font-bold text-white sm:size-9"
                  aria-hidden="true"
                >
                  ✓
                </span>
                <div>
                  <h3 class="text-base font-semibold text-tertiary sm:text-lg">
                    {row.title}
                  </h3>
                  <p class="mt-1 text-sm leading-relaxed text-tertiary/70 sm:text-[0.95rem]">
                    {row.body}
                  </p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <div
        class="flex min-h-[280px] flex-col gap-4 lg:relative lg:min-h-[480px] lg:justify-center"
      >
        <div
          class="flex items-center gap-4 rounded-none border border-gray-200 bg-white p-4 shadow-[0_10px_30px_rgba(0,0,0,0.1)] motion-safe:animate-nosotros-float motion-reduce:animate-none sm:p-5 lg:absolute lg:left-[4%] lg:top-[6%] lg:max-w-[16rem]"
        >
          <span class="flex shrink-0 text-secondary [&_svg]:size-9 sm:[&_svg]:size-10">
            <Zap aria-hidden="true" />
          </span>
          <div class="flex flex-col leading-tight">
            <strong class="text-lg text-tertiary sm:text-xl">Servicio</strong>
            <span class="text-sm text-tertiary/60">24/7</span>
          </div>
        </div>
        <div
          class="flex items-center gap-4 rounded-none border border-gray-200 bg-white p-4 shadow-[0_10px_30px_rgba(0,0,0,0.1)] motion-safe:animate-nosotros-float motion-reduce:animate-none sm:p-5 lg:absolute lg:right-[6%] lg:top-[42%] lg:max-w-[16rem]"
          style="animation-delay: 1s"
        >
          <span class="flex shrink-0 text-secondary [&_svg]:size-9 sm:[&_svg]:size-10">
            <Wrench aria-hidden="true" />
          </span>
          <div class="flex flex-col leading-tight">
            <strong class="text-lg text-tertiary sm:text-xl">Repuestos</strong>
            <span class="text-sm text-tertiary/60">Originales</span>
          </div>
        </div>
        <div
          class="flex items-center gap-4 rounded-none border border-gray-200 bg-white p-4 shadow-[0_10px_30px_rgba(0,0,0,0.1)] motion-safe:animate-nosotros-float motion-reduce:animate-none sm:p-5 lg:absolute lg:bottom-[8%] lg:left-[12%] lg:max-w-[16rem]"
          style="animation-delay: 2s"
        >
          <span class="flex shrink-0 text-secondary [&_svg]:size-9 sm:[&_svg]:size-10">
            <Check aria-hidden="true" />
          </span>
          <div class="flex flex-col leading-tight">
            <strong class="text-lg text-tertiary sm:text-xl">100%</strong>
            <span class="text-sm text-tertiary/60">Garantizado</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
