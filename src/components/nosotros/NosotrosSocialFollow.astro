---
import SocialBrandIconButtons from "../social/SocialBrandIconButtons.astro";
---

<section
  class="border-t-2 border-tertiary bg-white pb-14 pt-10 sm:pb-16 sm:pt-12 md:pb-20 md:pt-14"
  aria-labelledby="nosotros-social-heading"
>
  <div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
    <div
      class="mx-auto max-w-2xl border-2 border-tertiary bg-primary px-6 py-8 text-center shadow-[6px_6px_0_0_rgba(225,51,44,0.18)] sm:px-8 sm:py-10"
    >
      <p
        class="mb-3 inline-block border border-secondary/30 bg-secondary/10 px-4 py-1.5 text-[10px] font-bold uppercase tracking-[0.22em] text-secondary sm:text-xs"
      >
        Comunidad
      </p>
      <h2
        id="nosotros-social-heading"
        class="text-2xl font-semibold tracking-tight text-tertiary sm:text-3xl"
      >
        Síguenos en redes
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-tertiary/80 sm:text-base">
        Novedades, proyectos y un poco del día a día en el taller. Escríbenos por
        WhatsApp o únete en Instagram, Facebook y TikTok.
      </p>
      <div class="mt-8 flex justify-center">
        <SocialBrandIconButtons variant="inline" />
      </div>
    </div>
  </div>
</section>
