---
import { nosotrosGalleryItems } from "../../data/nosotrosGallery";

const sectionId = "galeria-nosotros";
---

<section
  id={sectionId}
  class="bg-white pb-0 pt-12 sm:pt-16 md:pt-20 lg:pt-24"
  aria-labelledby="nosotros-galeria-heading"
>
  <div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
    <header class="mx-auto mb-8 max-w-2xl text-center sm:mb-10 md:mb-12">
      <p
        class="mb-4 inline-block rounded-none border border-secondary/25 bg-secondary/15 px-5 py-2 text-xs font-bold uppercase tracking-[0.2em] text-secondary sm:text-sm"
      >
        Nuestra gente
      </p>
      <h2
        id="nosotros-galeria-heading"
        class="text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl"
      >
        Momentos que inspiran confianza
      </h2>
      <p
        class="mt-4 text-base leading-relaxed text-gray-600 sm:text-[1.05rem]"
      >
        Un vistazo a nuestro equipo en acción y a las instalaciones donde
        transformamos cada reto en resultados.
      </p>
    </header>
  </div>

  <p
    class="mx-auto mb-3 max-w-[1200px] px-4 text-center text-xs font-medium uppercase tracking-wider text-gray-400 sm:px-6 lg:hidden"
  >
    Desliza para ver todas las fotos
  </p>

  <div class="relative mx-auto max-w-[1200px]">
    <ul
      role="list"
      aria-label="Galería de fotos. Desplázate horizontalmente para ver cada imagen completa."
      class="nosotros-gallery-scroll m-0 flex list-none snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth px-4 pb-5 pt-1 [-webkit-overflow-scrolling:touch] [scrollbar-color:rgba(61,53,50,0.25)_transparent] [scrollbar-width:thin] motion-reduce:scroll-auto sm:gap-5 sm:px-6 sm:scroll-px-6 lg:gap-6 lg:px-8 lg:scroll-px-8"
    >
      {
        nosotrosGalleryItems.map((item) => (
          <li class="snap-center shrink-0 list-none">
            <figure
              class="group flex w-[min(82vw,17.5rem)] flex-col overflow-hidden rounded-none border border-gray-200/90 bg-white shadow-[0_12px_36px_rgba(0,0,0,0.07)] transition hover:shadow-[0_16px_44px_rgba(0,0,0,0.1)] sm:w-[min(72vw,19rem)] md:w-[min(56vw,20rem)] lg:w-[20.5rem]"
            >
              <a
                href={`#lightbox-${item.id}`}
                class="relative block cursor-zoom-in focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary"
              >
                <div
                  class="flex aspect-[4/5] w-full items-center justify-center bg-gray-100 p-2 sm:p-3 md:aspect-square"
                >
                  <img
                    src={item.src}
                    alt={item.alt}
                    loading="lazy"
                    decoding="async"
                    class="max-h-full max-w-full object-contain object-center transition duration-300 group-hover:opacity-95"
                    width={800}
                    height={600}
                  />
                </div>
              </a>
              <figcaption class="border-t border-gray-100 px-3 py-2.5 sm:px-3.5 sm:py-3">
                <span class="text-[0.65rem] font-bold uppercase tracking-wide text-secondary sm:text-xs">
                  {item.label}
                </span>
                <p class="mt-1 line-clamp-3 text-xs leading-snug text-gray-600 sm:text-[0.8125rem]">
                  {item.description}
                </p>
                <p class="mt-2 text-[0.65rem] text-gray-400">Toca para ampliar</p>
              </figcaption>
            </figure>
          </li>
        ))
      }
    </ul>
  </div>
</section>

{
  nosotrosGalleryItems.map((item) => (
    <div
      id={`lightbox-${item.id}`}
      class="fixed inset-0 z-[1000] hidden items-center justify-center bg-[rgba(20,16,15,0.9)] p-4 target:flex sm:p-8"
      role="dialog"
      aria-modal="true"
      aria-label={`Imagen ampliada: ${item.label}`}
    >
      <a
        href={`#${sectionId}`}
        class="absolute inset-0 cursor-zoom-out"
        aria-hidden="true"
        tabindex="-1"
      />
      <div class="relative z-[1] flex max-h-[92vh] max-w-[min(96vw,72rem)] items-center justify-center">
        <img
          src={item.src}
          alt={item.alt}
          loading="lazy"
          class="max-h-[92vh] w-auto max-w-full rounded-none object-contain shadow-[0_25px_60px_rgba(0,0,0,0.35)]"
        />
        <a
          href={`#${sectionId}`}
          class="absolute -right-1 -top-1 flex size-10 items-center justify-center bg-secondary text-xl font-semibold leading-none text-white shadow-lg transition hover:bg-secondary-dark sm:-right-2 sm:-top-2 sm:size-11 sm:text-2xl"
          aria-label="Cerrar galería"
        >
          &times;
        </a>
      </div>
    </div>
  ))
}

<style>
  .nosotros-gallery-scroll::-webkit-scrollbar {
    height: 6px;
  }
  .nosotros-gallery-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .nosotros-gallery-scroll::-webkit-scrollbar-thumb {
    background: rgb(61 53 50 / 0.22);
    border-radius: 0;
  }
  .nosotros-gallery-scroll::-webkit-scrollbar-thumb:hover {
    background: rgb(61 53 50 / 0.35);
  }
</style>
