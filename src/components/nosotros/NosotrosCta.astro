---
import { MessageCircle } from "@lucide/astro/icons";

const waNosotros =
  "https://api.whatsapp.com/send?phone=59170405030&text=" +
  encodeURIComponent(
    "¡Hola! Vengo de la página Nosotros y me interesa conocer más sobre Hydraulic Sistem.\n\n¿Podrían brindarme más información sobre sus servicios? Gracias.",
  );
---

<section
  class="relative isolate overflow-hidden bg-gradient-to-br from-tertiary to-tertiary-light py-14 sm:py-16 md:py-24"
  aria-labelledby="nosotros-cta-heading"
>
  <div
    class="pointer-events-none absolute inset-0 z-0 bg-[radial-gradient(circle,rgba(225,51,44,0.12)_1px,transparent_1px)] motion-safe:animate-nosotros-cta-pattern motion-reduce:animate-none [background-size:50px_50px]"
    aria-hidden="true"
  >
  </div>
  <div
    class="relative z-[1] mx-auto max-w-[50rem] px-4 text-center sm:px-6 lg:px-8"
  >
    <h2
      id="nosotros-cta-heading"
      class="text-balance text-[clamp(1.65rem,4vw,2.75rem)] font-extrabold leading-tight text-primary"
    >
      ¿Listo para trabajar con los mejores?
    </h2>
    <p
      class="mx-auto mt-4 max-w-2xl text-pretty text-base leading-relaxed text-primary/90 sm:mt-5 sm:text-lg"
    >
      Confía en nosotros para mantener tu maquinaria operativa con los más
      altos estándares de calidad
    </p>
    <div
      class="mt-8 flex flex-col items-stretch justify-center gap-3 sm:mt-10 sm:flex-row sm:flex-wrap sm:gap-4"
    >
      <a
        href={waNosotros}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-12 items-center justify-center gap-2 bg-secondary px-6 py-3 text-sm font-semibold text-white shadow-[0_10px_30px_rgba(225,51,44,0.3)] transition hover:-translate-y-0.5 hover:bg-secondary-dark hover:shadow-[0_14px_36px_rgba(225,51,44,0.38)] sm:min-h-0 sm:px-8 sm:py-3.5 sm:text-base"
      >
        <MessageCircle class="size-5 shrink-0 sm:size-6" aria-hidden="true" />
        Contáctanos por WhatsApp
      </a>
      <a
        href="/#servicios"
        class="inline-flex min-h-12 items-center justify-center border-2 border-primary bg-transparent px-6 py-3 text-sm font-semibold text-primary transition hover:-translate-y-0.5 hover:bg-primary hover:text-tertiary sm:min-h-0 sm:px-8 sm:py-3.5 sm:text-base"
      >
        Ver nuestros servicios
      </a>
    </div>
  </div>
</section>
