---
import Layout from "../layouts/Layout.astro";
import { Mail, MessageCircle, Phone, Send, Zap } from "@lucide/astro/icons";
---

<Layout>
  <!-- Hero Section -->
  <section class="hero-contacto">
    <div class="hero-content-contacto">
      <div class="hero-badge-contacto">Contáctanos</div>
      <h1 class="hero-title-contacto">
        Estamos Aquí para <span class="highlight-contacto">Ayudarte</span>
      </h1>
      <p class="hero-subtitle-contacto">
        ¿Tu maquinaria necesita atención? Contáctanos ahora y recibe asesoría profesional
      </p>
    
    </div>
  </section>

  <!-- Métodos de Contacto Rápido -->
  <section class="contacto-rapido">
    <div class="container-contacto">
      <div class="contacto-rapido-grid">
        <a href="https://api.whatsapp.com/send?phone=59170405030&text=¡Hola!%20👋%0A%0ANecesito%20información%20sobre%20sus%20productos%20y%20servicios%20hidráulicos.%0A%0A¿Podrían%20ayudarme?%20Gracias%20🙏" target="_blank" class="contacto-card whatsapp-card">
          <div class="contacto-icon-wrapper">
            <MessageCircle class="contacto-icon" size={40} aria-hidden="true" />
          </div>
          <h3>WhatsApp</h3>
          <p>Chatea con nosotros</p>
          <span class="contacto-value">+591 70405030</span>
          <div class="card-arrow">→</div>
        </a>

        <a href="tel:+59170405030" class="contacto-card telefono-card">
          <div class="contacto-icon-wrapper">
            <Phone class="contacto-icon" size={40} aria-hidden="true" />
          </div>
          <h3>Teléfono</h3>
          <p>Llámanos directamente</p>
          <span class="contacto-value">+591 70405030</span>
          <div class="card-arrow">→</div>
        </a>

        <a href="mailto:hydraulicssistem@gmail.com" class="contacto-card email-card">
          <div class="contacto-icon-wrapper">
            <Mail class="contacto-icon" size={40} aria-hidden="true" />
          </div>
          <h3>Email</h3>
          <p>Escríbenos un correo</p>
          <span class="contacto-value">hydraulicssistem@gmail.com</span>
          <div class="card-arrow">→</div>
        </a>
      </div>
    </div>
  </section>

  <!-- Información y Formulario -->
  <section class="contacto-main">
    <div class="container-contacto">
      <div class="contact-layout">
        <aside class="contact-info-panel">
          <div class="info-header">
            <h2>Información de Contacto</h2>
            <p>Estamos listos para ayudarte. Contáctanos por cualquiera de los siguientes medios o visítanos en Santa Cruz.</p>
          </div>

          <div class="info-grid">
            <div class="info-card">
              <h3>Datos de contacto</h3>
              <ul class="info-list">
                <li>
                  <span class="info-label">Ubicación</span>
                  <span class="info-value">Santa Cruz, Bolivia</span>
                </li>
                <li>
                  <span class="info-label">Teléfono</span>
                  <a class="info-link" href="tel:+59170405030">+591 70405030</a>
                </li>
                <li>
                  <span class="info-label">Email</span>
                  <a class="info-link" href="mailto:hydraulicssistem@gmail.com">hydraulicssistem@gmail.com</a>
                </li>
              </ul>
            </div>

            <div class="info-card">
              <h3>Horarios de atención</h3>
              <ul class="info-list">
                <li>
                  <span class="info-label">Lunes - Viernes</span>
                  <span class="info-value">8:00 - 18:00</span>
                </li>
                <li>
                  <span class="info-label">Sábado</span>
                  <span class="info-value">8:00 - 13:00</span>
                </li>
                <li>
                  <span class="info-label">Emergencias</span>
                  <span class="info-value">Disponibles 24/7</span>
                </li>
              </ul>
            </div>
          </div>
        </aside>

        <div class="contact-form-panel">
          <div class="formulario-header">
            <span class="section-badge-contacto">Envíanos un Mensaje</span>
            <h2 class="section-title-contacto">¿Tienes una Consulta?</h2>
            <p class="section-description-contacto">
              Completa el formulario y te responderemos a la brevedad posible
            </p>
          </div>

          <form class="contacto-form" id="contactForm">
            <div class="form-row">
              <div class="form-group">
                <label for="nombre">Nombre Completo *</label>
                <input type="text" id="nombre" name="nombre" required placeholder="Juan Pérez">
              </div>

              <div class="form-group">
                <label for="empresa">Empresa</label>
                <input type="text" id="empresa" name="empresa" placeholder="Tu empresa (opcional)">
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="telefono">Teléfono *</label>
                <input type="tel" id="telefono" name="telefono" required placeholder="+591 00000000">
              </div>

              <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" required placeholder="tu@email.com">
              </div>
            </div>

            <div class="form-group">
              <label for="asunto">Asunto *</label>
              <select id="asunto" name="asunto" required>
                <option value="">Selecciona un asunto</option>
                <option value="reparacion">Reparación de Equipo</option>
                <option value="repuestos">Consulta de Repuestos</option>
                <option value="emergencia">Servicio de Emergencia</option>
                <option value="cotizacion">Solicitar Cotización</option>
                <option value="mantenimiento">Mantenimiento Preventivo</option>
                <option value="otro">Otro</option>
              </select>
            </div>

            <div class="form-group">
              <label for="mensaje">Mensaje *</label>
              <textarea id="mensaje" name="mensaje" rows="5" required placeholder="Describe tu consulta o necesidad..."></textarea>
            </div>

            <button type="submit" class="btn-submit">
              <Send size={20} aria-hidden="true" />
              Enviar Mensaje
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Mapa Grande -->
  <section class="mapa-section">
    <div class="mapa-container">
      <div class="mapa-header">
        <h2>Encuéntranos</h2>
        <p>Visítanos en nuestra ubicación en Santa Cruz, Bolivia</p>
      </div>
      <div class="mapa-wrapper-grande">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1165.0934804011072!2d-63.213058726666084!3d-17.396015390313593!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x93ee3dd05358df59%3A0xf97c0eaed94ba305!2sHYDRAULICS%20SISTEM!5e0!3m2!1ses-419!2sbo!4v1760461550163!5m2!1ses-419!2sbo" 
          width="100%" 
          height="500" 
          style="border:0; border-radius: 20px;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="cta-contacto">
    <div class="container-contacto">
      <div class="cta-contacto-content">
        <h2>¿Necesitas Atención Inmediata?</h2>
        <p>Nuestro equipo está disponible 24/7 para emergencias</p>
        <a href="https://api.whatsapp.com/send?phone=59170405030&text=🚨%20EMERGENCIA%20HIDRÁULICA%20🚨%0A%0A¡Hola!%20Tengo%20una%20emergencia%20con%20mi%20equipo%20hidráulico%20y%20necesito%20atención%20inmediata.%0A%0APor%20favor,%20contáctenme%20lo%20antes%20posible.%20Gracias%20🙏" target="_blank" class="btn-emergencia">
          <Zap size={24} aria-hidden="true" />
          Contactar Servicio de Emergencia
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Contacto */
  .hero-contacto {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      linear-gradient(135deg, rgba(34, 30, 28, 0.65) 0%, rgba(34, 30, 28, 0.45) 100%),
      url('/hero-hydraulic.png') center/cover no-repeat;
    overflow: hidden;
  }

  .hero-contacto::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(circle at 30% 40%, rgba(225, 51, 44, 0.15) 0%, transparent 50%),
      radial-gradient(circle at 70% 60%, rgba(225, 51, 44, 0.1) 0%, transparent 50%);
    animation: pulse-bg-contacto 6s ease-in-out infinite;
  }

  @keyframes pulse-bg-contacto {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  .hero-content-contacto {
    position: relative;
    text-align: center;
    z-index: 10;
    max-width: 900px;
    padding: 2rem;
  }

  .hero-badge-contacto {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: rgba(233, 232, 232, 0.2);
    border: 1px solid rgba(233, 232, 232, 0.2);
    color: white;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .hero-title-contacto {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    color: var(--color-primary);
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .highlight-contacto {
    color: var(--color-secondary);
    position: relative;
  }

  .hero-subtitle-contacto {
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: rgba(241, 236, 232, 0.85);
    margin-bottom: 3rem;
  }


  /* Container */
  .container-contacto {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Contacto Rápido */
  .contacto-rapido {
    padding: 4rem 0;
    background: linear-gradient(to bottom, var(--color-primary) 0%, var(--color-white) 100%);
    margin-top: -3rem;
    position: relative;
    z-index: 10;
  }

  .contacto-rapido-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .contacto-card {
    background: var(--color-white);
    padding: 2.5rem;
    border-radius: 20px;
    box-shadow: 0 10px 40px var(--color-overlay-light);
    transition: all 0.4s ease;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .contacto-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 5px;
    transition: height 0.4s ease;
  }

  .whatsapp-card::before {
    background: linear-gradient(90deg, #25D366, #128C7E);
  }

  .telefono-card::before {
    background: linear-gradient(90deg, var(--color-secondary), var(--color-secondary-light));
  }

  .email-card::before {
    background: linear-gradient(90deg, #EA4335, #FBBC04);
  }

  .contacto-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 60px var(--color-overlay);
  }

  .contacto-card:hover::before {
    height: 100%;
  }

  .contacto-card:hover .contacto-icon-wrapper,
  .contacto-card:hover h3,
  .contacto-card:hover p,
  .contacto-card:hover .contacto-value {
    position: relative;
    z-index: 1;
    color: var(--color-white);
  }

  .contacto-icon-wrapper {
    width: 80px;
    height: 80px;
    background: rgba(225, 51, 44, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: all 0.4s ease;
  }

  .contacto-card:hover .contacto-icon-wrapper {
    background: rgba(255, 255, 255, 0.2);
  }

  .contacto-icon {
    width: 40px;
    height: 40px;
    color: var(--color-secondary);
    transition: color 0.4s ease;
  }

  .contacto-card:hover .contacto-icon {
    color: var(--color-white);
  }

  .contacto-card h3 {
    font-size: 1.5rem;
    color: var(--color-tertiary);
    margin-bottom: 0.5rem;
    font-weight: 700;
    transition: color 0.4s ease;
  }

  .contacto-card p {
    color: var(--color-gray-500);
    font-size: 0.95rem;
    margin-bottom: 1rem;
    transition: color 0.4s ease;
  }

  .contacto-value {
    font-size: 1.1rem;
    color: var(--color-tertiary);
    font-weight: 600;
    transition: color 0.4s ease;
  }

  .card-arrow {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    font-size: 2rem;
    color: var(--color-secondary);
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.4s ease;
  }

  .contacto-card:hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--color-white);
  }

  /* Bloque principal de contacto */
  .contacto-main {
    padding: 6rem 0;
    background: var(--color-white);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: 3rem;
    align-items: flex-start;
  }

  .contact-info-panel {
    background: var(--color-primary);
    border-radius: 20px;
    border: 1px solid rgba(61, 53, 50, 0.08);
    padding: 2.5rem;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact-form-panel {
    background: var(--color-primary);
    border-radius: 20px;
    border: 1px solid rgba(61, 53, 50, 0.08);
    padding: 2.5rem;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.08);
  }

  .section-badge-contacto {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background-color: rgba(225, 51, 44, 0.1);
    color: var(--color-secondary);
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  .section-title-contacto {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--color-tertiary);
    margin-bottom: 1rem;
  }

  .section-description-contacto {
    color: var(--color-gray-600);
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }

  /* Formulario */
  .contacto-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-weight: 600;
    color: var(--color-tertiary);
    font-size: 0.95rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 1rem;
    border: 2px solid var(--color-gray-200);
    border-radius: 10px;
    font-size: 1rem;
    transition: all 0.3s ease;
    font-family: inherit;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-secondary);
    box-shadow: 0 0 0 4px rgba(225, 51, 44, 0.1);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn-submit {
    padding: 1.2rem 2.5rem;
    background: var(--color-secondary);
    color: var(--color-white);
    border: none;
    border-radius: 10px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    box-shadow: 0 10px 30px rgba(225, 51, 44, 0.3);
  }

  .btn-submit:hover {
    background: var(--color-secondary-dark);
    transform: translateY(-2px);
    box-shadow: 0 15px 40px rgba(225, 51, 44, 0.4);
  }

  .info-header {
    text-align: left;
  }

  .info-header h2 {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--color-tertiary);
    margin-bottom: 0.75rem;
  }

  .info-header p {
    color: rgba(61, 53, 50, 0.7);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .info-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-card {
    background: var(--color-white);
    border-radius: 16px;
    border: 1px solid rgba(61, 53, 50, 0.08);
    padding: 1.75rem;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.06);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .info-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-tertiary);
    margin: 0;
  }

  .info-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .info-list li {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .info-label {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(61, 53, 50, 0.55);
    font-weight: 600;
  }

  .info-value {
    font-size: 1.1rem;
    color: var(--color-tertiary);
    font-weight: 600;
  }

  .info-link {
    font-size: 1.1rem;
    color: var(--color-secondary);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .info-link:hover {
    color: var(--color-secondary-dark);
  }

  /* Mapa Grande */
  .mapa-section {
    padding: 6rem 0;
    background: var(--color-white);
    position: relative;
    overflow: hidden;
  }

  .mapa-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-secondary), transparent);
  }

  .mapa-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .mapa-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .mapa-header h2 {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    color: var(--color-tertiary);
    margin-bottom: 1rem;
    position: relative;
  }

  .mapa-header h2::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, var(--color-secondary), var(--color-secondary-light));
    border-radius: 2px;
  }

  .mapa-header p {
    font-size: 1.2rem;
    color: var(--color-gray-600);
    max-width: 600px;
    margin: 0 auto;
  }

  .mapa-wrapper-grande {
    position: relative;
    border-radius: 25px;
    overflow: hidden;
    box-shadow: 0 25px 60px var(--color-overlay);
    transition: transform 0.3s ease;
  }

  .mapa-wrapper-grande:hover {
    transform: scale(1.02);
  }

  .mapa-wrapper-grande::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(45deg, rgba(225, 51, 44, 0.05), transparent, rgba(225, 51, 44, 0.05));
    pointer-events: none;
    z-index: 1;
  }

  /* CTA Contacto */
  .cta-contacto {
    padding: 4rem 0;
    background: linear-gradient(135deg, var(--color-tertiary) 0%, var(--color-tertiary-light) 100%);
    position: relative;
    overflow: hidden;
  }

  .cta-contacto::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(225, 51, 44, 0.1) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: movePattern 20s linear infinite;
  }

  @keyframes movePattern {
    0% { background-position: 0 0; }
    100% { background-position: 50px 50px; }
  }

  .cta-contacto-content {
    position: relative;
    text-align: center;
    z-index: 10;
  }

  .cta-contacto-content h2 {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .cta-contacto-content p {
    font-size: 1.1rem;
    color: rgba(241, 236, 232, 0.9);
    margin-bottom: 2.5rem;
  }

  .btn-emergencia {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.2rem 2.5rem;
    background: var(--color-secondary);
    color: var(--color-white);
    text-decoration: none;
    font-weight: 600;
    border-radius: 10px;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(225, 51, 44, 0.3);
    animation: pulse-button 2s infinite;
  }

  @keyframes pulse-button {
    0%, 100% {
      box-shadow: 0 10px 30px rgba(225, 51, 44, 0.3);
    }
    50% {
      box-shadow: 0 10px 50px rgba(225, 51, 44, 0.6);
    }
  }

  .btn-emergencia:hover {
    background: var(--color-secondary-dark);
    transform: translateY(-3px);
  }

  /* Responsive */
  @media (max-width: 968px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .contacto-rapido-grid {
      grid-template-columns: 1fr;
    }

    .contact-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .contact-info-panel {
      order: 2;
    }

    .contact-form-panel {
      order: 1;
    }

    .mapa-container {
      padding: 0 1rem;
    }
  }

  @media (max-width: 640px) {
    .contacto-main,
    .mapa-section,
    .contacto-rapido,
    .cta-contacto {
      padding: 3rem 0;
    }

    .contact-info-panel,
    .contact-form-panel {
      padding: 2rem;
    }

    .mapa-wrapper-grande {
      border-radius: 15px;
    }
  }

</style>

<script>
  // Manejo del formulario
  const form = document.getElementById('contactForm') as HTMLFormElement;
  
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = {
        nombre: formData.get('nombre'),
        empresa: formData.get('empresa'),
        telefono: formData.get('telefono'),
        email: formData.get('email'),
        asunto: formData.get('asunto'),
        mensaje: formData.get('mensaje')
      };
      
      // Crear mensaje para WhatsApp
      const mensaje = `📧 Nuevo contacto desde la web\n\n` +
        `👤 Nombre: ${data.nombre}\n` +
        `🏢 Empresa: ${data.empresa || 'No especificada'}\n` +
        `📱 Teléfono: ${data.telefono}\n` +
        `✉️ Email: ${data.email}\n` +
        `📋 Asunto: ${data.asunto}\n\n` +
        `💬 Mensaje:\n${data.mensaje}\n\n` +
        `Gracias por contactarnos 🙏`;
      
      const mensajeCodificado = encodeURIComponent(mensaje);
      const whatsappURL = `https://api.whatsapp.com/send?phone=59170405030&text=${mensajeCodificado}`;
      
      // Abrir WhatsApp
      window.open(whatsappURL, '_blank');
      
      // Limpiar formulario
      form.reset();
      
      // Mostrar mensaje de éxito
      alert('¡Gracias por tu mensaje! Te contactaremos pronto.');
    });
  }
</script>