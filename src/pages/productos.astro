---
import Layout from "../layouts/Layout.astro";
import ProductModal from "../components/ProductModal.astro";
import { SEO_PRODUCTOS } from "../data/siteSeo";
import {
  ChevronDown,
  Factory,
  Filter,
  LoaderCircle,
  Search,
  SlidersVertical,
} from "@lucide/astro/icons";
---

<Layout footerFlushTop {...SEO_PRODUCTOS}>
  <section class="relative min-h-[50vh] bg-gray-50 py-6 pb-24 sm:min-h-[60vh] sm:py-9 sm:pb-9 lg:py-12">
    <div
      class="mx-auto grid max-w-[1400px] gap-5 px-3 sm:gap-7 sm:px-5 lg:grid-cols-[minmax(260px,300px)_1fr] lg:items-start lg:gap-10 lg:px-8"
    >
      <!-- Header + buscador (en móvil va arriba; en desktop a la derecha) -->
      <div class="min-w-0 lg:col-start-2 lg:row-start-1">
        <header class="mb-5 sm:mb-7 lg:mb-8">
          <h2
            class="text-[clamp(1.25rem,4.5vw,1.875rem)] font-medium leading-tight tracking-tight text-gray-900 sm:text-3xl"
          >
            Catálogo de componentes
          </h2>
          <div
            class="mt-2 h-1 w-[min(6.5rem,38vw)] max-w-[10rem] rounded-sm bg-secondary"
            aria-hidden="true"
          >
          </div>
          <p
            class="mt-3 max-w-3xl text-[0.8125rem] leading-relaxed text-gray-600 sm:mt-4 sm:text-sm sm:leading-relaxed lg:text-[0.95rem]"
          >
            Nuestra ingeniería de precisión orienta el rendimiento en entornos
            industriales exigentes. Explore repuestos y piezas hidráulicas de
            alta calidad, pensados para durabilidad y una operación confiable de
            su maquinaria.
          </p>
          <p
            id="catalogoSubtituloTotal"
            class="mt-2.5 text-[11px] font-normal text-gray-500 sm:mt-3 sm:text-xs"
          >
            Cargando catálogo…
          </p>
        </header>

        <div
          class="mb-5 flex flex-col gap-3 rounded-xl border border-gray-200 bg-white p-3 shadow-sm sm:mb-6 sm:gap-3.5 sm:rounded-lg sm:p-4 lg:flex-row lg:flex-wrap lg:items-center lg:justify-between lg:gap-4"
        >
          <div class="relative min-w-0 flex-1 lg:max-w-md">
            <label for="busqueda" class="sr-only">Buscar en catálogo</label>
            <Search
              class="pointer-events-none absolute left-3 top-1/2 size-4 -translate-y-1/2 text-gray-400"
              aria-hidden="true"
            />
            <input
              type="search"
              id="busqueda"
              placeholder="Buscar por número de parte o modelo…"
              class="min-h-11 w-full rounded-lg border border-gray-200 bg-gray-50/90 py-2.5 pl-10 pr-3 text-[0.8125rem] font-normal text-gray-900 outline-none transition placeholder:text-gray-400 focus:border-secondary focus:bg-white focus:ring-2 focus:ring-secondary/15 sm:min-h-0 sm:rounded-md sm:text-[13px]"
              autocomplete="off"
            />
          </div>
          <p
            id="catalogoResultadosResumen"
            class="text-pretty text-center text-[0.6rem] font-normal uppercase leading-snug tracking-[0.1em] text-gray-500 sm:text-[0.65rem] sm:tracking-[0.12em] lg:max-w-[14rem] lg:shrink-0 lg:text-left"
          >
            —
          </p>
          <div class="relative min-w-0 lg:w-auto">
            <label for="ordenar" class="sr-only">Ordenar resultados</label>
            <select
              id="ordenar"
              class="min-h-11 w-full appearance-none rounded-lg border border-gray-200 bg-white py-2.5 pl-3 pr-10 text-left text-[11px] font-medium uppercase tracking-wide text-gray-800 outline-none focus:border-secondary focus:ring-2 focus:ring-secondary/15 sm:min-h-0 sm:rounded-md lg:min-w-[13rem]"
            >
              <option value="nombre-asc">Orden: nombre A–Z</option>
              <option value="nombre-desc">Orden: nombre Z–A</option>
            </select>
            <ChevronDown
              class="pointer-events-none absolute right-3 top-1/2 size-4 -translate-y-1/2 text-gray-500 sm:right-2.5"
              aria-hidden="true"
            />
          </div>
        </div>

      </div>

      <!-- Filtros (en móvil debajo del buscador; en desktop barra lateral) -->
      <aside
        id="filtrosCatalogoAside"
        class="w-full overflow-visible border-gray-200 bg-white lg:col-start-1 lg:row-start-1 lg:rounded-xl lg:border lg:shadow-sm lg:transition-none lg:sticky lg:top-24 lg:self-start lg:max-h-[calc(100dvh-6rem)] lg:overflow-y-auto"
        aria-label="Filtros del catálogo"
      >
        <div
          class="flex shrink-0 items-center justify-start border-b border-gray-100 px-4 py-3 lg:hidden gap-2"
        >
          <div class="flex items-center gap-2">
            <Filter class="size-4 text-secondary" aria-hidden="true" stroke-width={2} />
            <span class="text-sm font-medium text-gray-900">Filtros</span>
          </div>
        </div>

        <div class="min-h-0 flex-1 overflow-y-auto overscroll-contain lg:overflow-visible">
        <div class="border-b border-gray-100 px-3 py-3 sm:px-4 lg:border-t-0">
          <h1 class="text-base font-medium tracking-tight text-gray-900 max-lg:sr-only">
            Filtrar catálogo
          </h1>
          <p class="mt-0.5 text-[0.65rem] font-normal uppercase tracking-wider text-gray-500 max-lg:hidden">
            Especificaciones técnicas
          </p>
        </div>

        <div class="divide-y divide-gray-100">
          <details class="filtros-details">
            <summary
              class="flex cursor-pointer list-none items-center gap-2 bg-white px-3 py-2 outline-none marker:content-none hover:bg-gray-50 [&::-webkit-details-marker]:hidden sm:px-4"
            >
              <Filter
                class="size-3.5 shrink-0 text-gray-500"
                aria-hidden="true"
                stroke-width={2}
              />
              <span class="flex-1 text-left text-[11px] font-normal uppercase tracking-wide text-gray-700"
                >Categoría</span
              >
            </summary>
            <div class="space-y-0 bg-white px-3 pb-2 pt-0.5 sm:px-4">
              {
                [
                  ["bombas", "Bombas"],
                  ["cilindros", "Cilindros"],
                  ["valvulas", "Válvulas"],
                  ["motores", "Motores"],
                  ["comandos", "Comandos"],
                  ["kits", "Kits"],
                  ["direccion", "Dirección"],
                  ["otros", "Otros"],
                ].map(([value, label]) => (
                  <label class="filtro-check flex cursor-pointer items-center gap-2 py-1.5 text-[13px] font-normal text-gray-700">
                    <input
                      type="checkbox"
                      name="filtro-categoria"
                      value={value}
                      class="filtro-checkbox size-3.5 shrink-0 rounded border-gray-300 text-secondary focus:ring-secondary"
                    />
                    <span>{label}</span>
                  </label>
                ))
              }
            </div>
          </details>

          <details class="filtros-details">
            <summary
              class="flex cursor-pointer list-none items-center gap-2 bg-white px-3 py-2 outline-none marker:content-none hover:bg-gray-50 [&::-webkit-details-marker]:hidden sm:px-4"
            >
              <Factory
                class="size-3.5 shrink-0 text-gray-500"
                aria-hidden="true"
                stroke-width={2}
              />
              <span class="flex-1 text-left text-[11px] font-normal uppercase tracking-wide text-gray-700"
                >Marca</span
              >
            </summary>
            <div
              id="filtro-marca-checkboxes"
              class="max-h-40 space-y-0 overflow-y-auto bg-white px-3 pb-2 pt-0.5 sm:px-4"
            >
            </div>
          </details>

          <details class="filtros-details">
            <summary
              class="flex cursor-pointer list-none items-center gap-2 bg-white px-3 py-2 outline-none marker:content-none hover:bg-gray-50 [&::-webkit-details-marker]:hidden sm:px-4"
            >
              <SlidersVertical
                class="size-3.5 shrink-0 text-gray-500"
                aria-hidden="true"
                stroke-width={2}
              />
              <span class="flex-1 text-left text-[11px] font-normal uppercase tracking-wide text-gray-700"
                >Modelo compatible</span
              >
            </summary>
            <div
              id="filtro-modelo-checkboxes"
              class="max-h-44 space-y-0 overflow-y-auto bg-white px-3 pb-2 pt-0.5 sm:px-4"
            >
            </div>
          </details>
        </div>

        <div class="px-3 py-2.5 sm:px-4">
          <button
            type="button"
            id="btnLimpiar"
            class="w-full rounded-md border border-gray-800 bg-white py-2 text-center text-[11px] font-normal uppercase tracking-wide text-gray-800 transition hover:bg-gray-900 hover:text-white"
          >
            Limpiar filtros
          </button>
        </div>
        </div>
      </aside>

      <div class="min-w-0 lg:col-start-2 lg:row-start-2">
        <div
          id="productosGrid"
          class="grid grid-cols-2 gap-2 sm:gap-4 sm:grid-cols-2 xl:grid-cols-3"
        >
          <div
            id="loadingState"
            class="col-span-full flex flex-col items-center justify-center gap-4 py-20 text-gray-500"
          >
            <LoaderCircle
              class="size-12 shrink-0 animate-spin text-secondary"
              aria-hidden="true"
            />
            <p class="m-0 text-sm font-normal">Cargando productos…</p>
          </div>
        </div>

        <nav
          id="paginacionCatalogo"
          class="mt-6 hidden max-w-full flex-wrap items-center justify-center gap-1.5 px-1 sm:mt-8 sm:gap-2"
          aria-label="Paginación del catálogo"
        >
        </nav>
      </div>
    </div>
  </section>

  <ProductModal products={[]} phoneNumber="59170405030" />
</Layout>

<script>
  // @ts-nocheck
  import { ChevronLeft, ChevronRight, CircleAlert } from "lucide";
  import { pc } from "../data/productCardTailwind";
  import { lucideToHtml } from "../utils/lucideHtml";

  let filtrosMobileSheetInitDone = false;

  /** Registra FAB, backdrop y teclado del panel de filtros móvil (independiente de la carga de productos). */
  function initFiltrosMobileSheet() {
    if (filtrosMobileSheetInitDone) return;
    const filtrosAside = document.getElementById("filtrosCatalogoAside");
    const filtrosMobileBackdrop = document.getElementById(
      "filtrosMobileBackdrop",
    );
    const btnFiltrosMobileFab = document.getElementById("btnFiltrosMobileFab");
    const btnCerrarFiltrosMobile = document.getElementById(
      "btnCerrarFiltrosMobile",
    );
    if (!filtrosAside) return;
    filtrosMobileSheetInitDone = true;

    function setFiltrosMobileOpen(open) {
      const mobile =
        typeof window !== "undefined" && window.innerWidth < 1024;
      filtrosAside.setAttribute("data-open", open ? "true" : "false");
      console.log(
        `[productos.astro] filtrosMobile sheet -> ${open ? "open" : "closed"}`,
      );
      // No dependemos de `mobile` para aplicar la clase:
      // el CSS (media query) decide si realmente se traduce al abrir/cerrar.
      filtrosAside.classList.toggle("filtros-catalogo-sheet-open", open);

      // Fallback: por si alguna variant no aplica como esperamos, forzamos el
      // transform al abrir. Al cerrar, limpiamos para que el Tailwind manda.
      if (open) {
        filtrosAside.style.transform = "translateY(0)";
        filtrosAside.style.opacity = "1";
        filtrosAside.style.visibility = "visible";
        filtrosAside.style.pointerEvents = "auto";
        filtrosAside.style.boxShadow =
          "0 -12px 40px rgba(0, 0, 0, 0.22), 0 25px 50px -12px rgba(0, 0, 0, 0.25)";
      } else {
        filtrosAside.style.transform = "translateY(100%)";
        filtrosAside.style.opacity = "0";
        filtrosAside.style.visibility = "hidden";
        filtrosAside.style.pointerEvents = "none";
        filtrosAside.style.boxShadow = "";
      }
      btnFiltrosMobileFab?.setAttribute(
        "aria-expanded",
        open ? "true" : "false",
      );
      if (filtrosMobileBackdrop) {
        filtrosMobileBackdrop.classList.toggle("opacity-0", !open);
        filtrosMobileBackdrop.classList.toggle("pointer-events-none", !open);
        filtrosMobileBackdrop.classList.toggle("pointer-events-auto", open);
        filtrosMobileBackdrop.setAttribute(
          "aria-hidden",
          open ? "false" : "true",
        );
      }
      document.body.style.overflow = open && mobile ? "hidden" : "";
    }

    function toggleFiltrosMobile() {
      const open = filtrosAside.getAttribute("data-open") === "true";
      setFiltrosMobileOpen(!open);
    }

    btnFiltrosMobileFab?.addEventListener("click", () => {
      toggleFiltrosMobile();
    });
    btnCerrarFiltrosMobile?.addEventListener("click", () => {
      setFiltrosMobileOpen(false);
    });
    filtrosMobileBackdrop?.addEventListener("click", () => {
      setFiltrosMobileOpen(false);
    });
    // Importante: el viewport móvil puede "cambiar" cuando aparece/desaparece la barra del navegador.
    // Solo cerramos si realmente salimos del breakpoint mobile (para que no se abra y se vuelva a cerrar).
    const mqMobile = window.matchMedia("(max-width: 1023px)");
    window.addEventListener("resize", () => {
      const openNow = filtrosAside?.getAttribute("data-open") === "true";
      if (!openNow) return;
      if (mqMobile.matches) return; // seguimos en mobile => no cerrar
      setFiltrosMobileOpen(false); // salimos a desktop/tablet
    });
    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      if (filtrosAside.getAttribute("data-open") === "true") {
        setFiltrosMobileOpen(false);
      }
    });
  }

  document.addEventListener("DOMContentLoaded", async () => {
    console.log('🎬 [productos.astro] DOM cargado, iniciando carga de productos...');
    /** @type {Array<any>} */
    let productos = [];
    
    // Cargar productos desde Supabase (con fallback automático a JSON)
    try {
      console.log('📥 [productos.astro] Importando productService...');
      const { productService } = await import('../utils/productService');
      console.log('✅ [productos.astro] productService importado correctamente');
      
      console.log('🔄 [productos.astro] Llamando a productService.getAll()...');
      productos = await productService.getAll();
      console.log('✅ [productos.astro] Productos obtenidos:', productos.length);
      console.log('📋 [productos.astro] Lista de productos recibidos:');
      productos.forEach((p, index) => {
        console.log(`  ${index + 1}. ID: ${p.id}, Nombre: ${p.nombre?.substring(0, 50)}...`);
      });
      
      // Verificar si están los nuevos productos
      const nuevosProductos = productos.filter(p => 
        p.id.includes('rexroth') || p.id.includes('kit-componentes')
      );
      console.log('🆕 [productos.astro] Productos REXROTH en la lista:', nuevosProductos.length);
      if (nuevosProductos.length > 0) {
        nuevosProductos.forEach(p => {
          console.log('  ✅ Encontrado:', p.id, '-', p.nombre);
        });
      } else {
        console.warn('  ⚠️ NO se encontraron los productos REXROTH en la lista');
      }
      
      if (productos.length === 0) {
        console.warn('⚠️ [productos.astro] No se encontraron productos (ni en Supabase ni en JSON)');
        // Mostrar mensaje si no hay productos en absoluto
        const productosGrid = document.getElementById("productosGrid");
        if (productosGrid) {
          productosGrid.innerHTML = `
            <div class="col-span-full flex flex-col items-center justify-center gap-4 py-16 text-center text-gray-500">
              ${lucideToHtml(CircleAlert, { width: 48, height: 48, class: "text-secondary" })}
              <p class="m-0 text-sm font-normal">No se encontraron productos disponibles.</p>
            </div>
          `;
        }
        const st0 = document.getElementById("catalogoSubtituloTotal");
        const rs0 = document.getElementById("catalogoResultadosResumen");
        const pg0 = document.getElementById("paginacionCatalogo");
        if (st0) st0.textContent = "Sin piezas en catálogo";
        if (rs0) rs0.textContent = "Sin resultados";
        if (pg0) {
          pg0.classList.add("hidden");
          pg0.innerHTML = "";
        }
        return;
      }
    } catch (error) {
      console.error('❌ [productos.astro] Error crítico al cargar productos:', error);
      console.error('❌ [productos.astro] Stack trace:', error.stack);
      // Mostrar mensaje de error solo si hay un error crítico
      const productosGrid = document.getElementById("productosGrid");
      if (productosGrid) {
        productosGrid.innerHTML = `
          <div class="col-span-full flex flex-col items-center justify-center gap-4 py-16 text-center text-gray-500">
            ${lucideToHtml(CircleAlert, { width: 48, height: 48, class: "text-secondary" })}
            <p class="m-0 text-sm font-normal">Error al cargar productos. Por favor, recarga la página.</p>
          </div>
        `;
      }
      const stE = document.getElementById("catalogoSubtituloTotal");
      const rsE = document.getElementById("catalogoResultadosResumen");
      const pgE = document.getElementById("paginacionCatalogo");
      if (stE) stE.textContent = "—";
      if (rsE) rsE.textContent = "Error al cargar el catálogo";
      if (pgE) {
        pgE.classList.add("hidden");
        pgE.innerHTML = "";
      }
      return;
    }
    
    // El modal no necesita actualización ya que usa la función abrirModalProducto
    // que recibe el producto directamente

    // Renderizar productos
    const productosGrid = document.getElementById("productosGrid");
    const catalogoSubtituloTotal = document.getElementById(
      "catalogoSubtituloTotal",
    );
    const catalogoResultadosResumen = document.getElementById(
      "catalogoResultadosResumen",
    );
    const paginacionCatalogo = document.getElementById("paginacionCatalogo");
    const loadingState = document.getElementById("loadingState");
    const marcaCheckboxWrap = document.getElementById("filtro-marca-checkboxes");
    const modeloCheckboxWrap = document.getElementById("filtro-modelo-checkboxes");
    
    // Ocultar estado de carga
    if (loadingState) {
      loadingState.remove();
    }
    
    if (catalogoSubtituloTotal) {
      catalogoSubtituloTotal.textContent =
        productos.length === 1
          ? "1 pieza en catálogo"
          : `${productos.length} piezas en catálogo`;
    }
    
    /** Inferencia de categorías desde nombre y descripción (filtros multi‑opción). */
    function inferCategorias(producto) {
      const t = `${producto.nombre || ""} ${producto.descripcion || ""}`.toLowerCase();
      const s = new Set();
      if (/\bbomba|bombas|engranaje\b/.test(t)) s.add("bombas");
      if (/cilindro/.test(t)) s.add("cilindros");
      if (/válvula|valvula/.test(t)) s.add("valvulas");
      if (/\bmotor\b|motores hidráulicos|motor hidráulico/.test(t)) s.add("motores");
      if (/comando/.test(t)) s.add("comandos");
      if (/\bkit\b/.test(t)) s.add("kits");
      if (/direcci[oó]n|orbitrol/.test(t)) s.add("direccion");
      if (s.size === 0) s.add("otros");
      return Array.from(s);
    }

    // Función para extraer marcas de un producto
    function extraerMarcas(producto) {
      const marcas = new Set();
      const marcasConocidas = [
        'KAWASAKI', 'REXROTH', 'CATERPILLAR', 'SAUER', 'SUNDSTRAND',
        'LINDE', 'KOMATSU', 'VICKERS', 'EATON', 'PARKER', 'HITACHI',
        'MEDAL', 'MOTOCANA'
      ];
      
      // Buscar marcas en modelos_compatibles
      if (producto.modelos_compatibles) {
        producto.modelos_compatibles.forEach((modelo) => {
          marcasConocidas.forEach((marca) => {
            if (modelo.toUpperCase().includes(marca)) {
              marcas.add(marca);
            }
          });
        });
      }
      
      // Buscar marcas en el nombre
      const nombreUpper = producto.nombre?.toUpperCase() || '';
      marcasConocidas.forEach((marca) => {
        if (nombreUpper.includes(marca)) {
          marcas.add(marca);
        }
      });
      
      // Buscar "PARKER HANNIFIN" como "PARKER"
      if (nombreUpper.includes('PARKER HANNIFIN') || nombreUpper.includes('PARKER')) {
        marcas.add('PARKER');
      }
      
      // Buscar "SAUER SUNDSTRAND" como "SAUER SUNDSTRAND"
      if (nombreUpper.includes('SAUER SUNDSTRAND')) {
        marcas.add('SAUER SUNDSTRAND');
      } else if (nombreUpper.includes('SAUER')) {
        marcas.add('SAUER');
      }
      
      return Array.from(marcas);
    }
    
    // Generar opciones de modelos
    const modelOptions = Array.from(
      new Set(productos.flatMap((p) => p.modelos_compatibles ?? []))
    ).sort((a, b) => a.localeCompare(b));
    
    const todasLasMarcas = new Set();
    productos.forEach((producto) => {
      const marcas = extraerMarcas(producto);
      marcas.forEach((marca) => todasLasMarcas.add(marca));
    });

    const marcasOrdenadas = Array.from(todasLasMarcas).sort((a, b) =>
      a.localeCompare(b),
    );

    function escapeHtml(str) {
      if (str == null || str === "") return "";
      return String(str)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    const filaCheckbox = (name, valor, etiqueta) => {
      const v = escapeHtml(valor);
      const e = escapeHtml(etiqueta);
      return `<label class="filtro-check flex cursor-pointer items-center gap-2 py-1.5 text-[13px] font-normal text-gray-700" title="${v}"><input type="checkbox" name="${name}" value="${v}" class="filtro-checkbox size-3.5 shrink-0 rounded border-gray-300 text-secondary focus:ring-secondary" /><span class="min-w-0 truncate">${e}</span></label>`;
    };

    if (marcaCheckboxWrap) {
      marcaCheckboxWrap.innerHTML = marcasOrdenadas
        .map((marca) => filaCheckbox("filtro-marca", marca, marca))
        .join("");
    }

    if (modeloCheckboxWrap) {
      modeloCheckboxWrap.innerHTML = modelOptions
        .map((modelo) => filaCheckbox("filtro-modelo", modelo, modelo))
        .join("");
    }

    // Función para renderizar una tarjeta de producto
    function renderProductCard(producto) {
      const modelos = producto.modelos_compatibles ?? [];
      const marcas = extraerMarcas(producto);
      const marcaEtiqueta = marcas[0] || "HYDRAULIC SISTEM";
      const imagenes = producto.imagen
        ? Array.isArray(producto.imagen)
          ? producto.imagen
          : [producto.imagen]
        : ["/placeholder-producto.jpg"];
      const tieneImagen = imagenes.length > 0 && imagenes[0] !== "/placeholder-producto.jpg";
      const tieneMultiplesImagenes = imagenes.length > 1;
      const nombreEsc = escapeHtml(producto.nombre);
      const descEsc = escapeHtml(producto.descripcion || "");
      const refLine =
        modelos.length > 0
          ? `Ref. ${escapeHtml(modelos.slice(0, 4).join(" · "))}${modelos.length > 4 ? "…" : ""}`
          : "";

      const card = document.createElement("div");
      card.className = pc.card;
      card.setAttribute("data-producto-id", producto.id);
      card.setAttribute("data-modelos", modelos.join(","));
      card.setAttribute("data-marcas", marcas.join(","));
      card.setAttribute(
        "data-categorias",
        inferCategorias(producto).join(","),
      );
      card.setAttribute("data-imagen", tieneImagen ? "true" : "false");

      card.innerHTML = `
        <div class="${pc.imagenWrap}">
          <div class="${pc.imgContainer}">
            ${imagenes
              .map(
                (img, index) => `
              <img
                src="${escapeHtml(img)}"
                alt="${nombreEsc} - Imagen ${index + 1}"
                loading="lazy"
                class="${pc.img}${index === 0 ? " active" : ""}"
                data-image-index="${index}"
              />
            `,
              )
              .join("")}
          </div>
          ${tieneMultiplesImagenes ? `
            <button class="${pc.navPrev}" type="button" aria-label="Imagen anterior" data-producto-id="${escapeHtml(producto.id)}">
              ${lucideToHtml(ChevronLeft, { width: 16, height: 16 })}
            </button>
            <button class="${pc.navNext}" type="button" aria-label="Imagen siguiente" data-producto-id="${escapeHtml(producto.id)}">
              ${lucideToHtml(ChevronRight, { width: 16, height: 16 })}
            </button>
            <div class="${pc.indicators}">
              ${imagenes
                .map(
                  (_, index) => `
                <button class="${pc.indicator}${index === 0 ? " active" : ""}" type="button" aria-label="Ver imagen ${index + 1}" data-image-index="${index}" data-producto-id="${escapeHtml(producto.id)}"></button>
              `,
                )
                .join("")}
            </div>
          ` : ""}
        </div>
        <div class="${pc.info}">
          <p class="${pc.marca}">${escapeHtml(marcaEtiqueta)}</p>
          <h4 class="${pc.nombre}">${nombreEsc}</h4>
          <p class="${pc.descripcion}">${descEsc}</p>
          ${refLine ? `<p class="${pc.compat}">${refLine}</p>` : ""}
          <div class="${pc.precioRow}">
            <div class="${pc.precioBloque}">
              <span class="${pc.precio}">Consultar</span>
              <span class="${pc.precioMeta}">precio</span>
            </div>
            <button
              class="${pc.infoBtn}"
              type="button"
              aria-label="Ver detalles de ${nombreEsc}"
              data-producto-id="${escapeHtml(producto.id)}"
            >Ver detalles</button>
          </div>
          <div class="${pc.cantidadFila}">
            <span class="${pc.cantidadLabel}">Cantidad</span>
            <div class="${pc.cantidadControl}" data-producto-id="${escapeHtml(producto.id)}">
              <button class="${pc.cantidadBtn}" type="button" data-action="decremento" aria-label="Disminuir cantidad">&minus;</button>
              <input class="${pc.cantidadInput}" type="number" min="1" step="1" value="1" inputmode="numeric" aria-label="Cantidad" />
              <button class="${pc.cantidadBtn}" type="button" data-action="incremento" aria-label="Aumentar cantidad">+</button>
            </div>
          </div>
          <div class="${pc.actions}">
            <button class="${pc.btnCarrito}" type="button" data-producto-id="${escapeHtml(producto.id)}">
              Añadir al carrito
            </button>
          </div>
        </div>
      `;

      return card;
    }
    
    // Renderizar todos los productos
    console.log('🎨 [productos.astro] Iniciando renderizado de productos...');
    if (productosGrid) {
      productosGrid.innerHTML = "";
      console.log(`🖼️ [productos.astro] Renderizando ${productos.length} productos...`);
      
      productos.forEach((producto, index) => {
        console.log(`  📦 [productos.astro] Renderizando producto ${index + 1}/${productos.length}: ${producto.id}`);
        const card = renderProductCard(producto);
        productosGrid.appendChild(card);
      });
      
      console.log('✅ [productos.astro] Renderizado completado');
      console.log(`📊 [productos.astro] Total de cards en el DOM: ${productosGrid.children.length}`);
    } else {
      console.error('❌ [productos.astro] No se encontró el elemento productosGrid');
    }

    const busquedaInput = document.getElementById("busqueda");
    const btnLimpiar = document.getElementById("btnLimpiar");
    const filtrosAside = document.getElementById("filtrosCatalogoAside");

    function valoresCheckbox(name) {
      return Array.from(
        document.querySelectorAll(`input[name="${name}"]:checked`),
      ).map((el) => el.value);
    }

    const imagenesProductos = Array.from(
      document.querySelectorAll(".producto-imagen-img"),
    );

    const ajustarImagen = (img) => {
      if (!img || !img.complete || !img.naturalWidth || !img.naturalHeight)
        return;
      if (img.naturalWidth > img.naturalHeight) {
        img.classList.add("scale-90");
      } else {
        img.classList.remove("scale-90");
      }
    };

    imagenesProductos.forEach((img) => {
      if (img.complete) {
        ajustarImagen(img);
      } else {
        img.addEventListener("load", () => ajustarImagen(img));
      }
    });

    // Inicializar carrusel de imágenes
    productosGrid?.querySelectorAll(".producto-imagen").forEach((container) => {
      const images = container.querySelectorAll(".producto-imagen-img");
      const prevBtn = container.querySelector(".producto-imagen-prev");
      const nextBtn = container.querySelector(".producto-imagen-next");
      const indicators = container.querySelectorAll(".producto-imagen-indicator");
      
      if (images.length <= 1) return;

      let currentIndex = 0;

      const showImage = (index) => {
        images.forEach((img, i) => {
          img.classList.toggle("active", i === index);
        });
        indicators.forEach((indicator, i) => {
          indicator.classList.toggle("active", i === index);
        });
        currentIndex = index;
      };

      prevBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        const newIndex = currentIndex === 0 ? images.length - 1 : currentIndex - 1;
        showImage(newIndex);
      });

      nextBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        const newIndex = currentIndex === images.length - 1 ? 0 : currentIndex + 1;
        showImage(newIndex);
      });

      indicators.forEach((indicator, index) => {
        indicator.addEventListener("click", (e) => {
          e.stopPropagation();
          showImage(index);
        });
      });
    });

    // Inicializar controles de cantidad
    productosGrid?.querySelectorAll(".cantidad-control").forEach((control) => {
      const input = control.querySelector(".cantidad-input");
      const decrementar = control.querySelector('[data-action="decremento"]');
      const incrementar = control.querySelector('[data-action="incremento"]');

      const actualizarCantidad = (delta) => {
        if (!input) return;
        const actual = Number(input.value) || 1;
        const nuevo = Math.max(1, actual + delta);
        input.value = String(nuevo);
      };

      decrementar?.addEventListener("click", () => actualizarCantidad(-1));
      incrementar?.addEventListener("click", () => actualizarCantidad(1));

      input?.addEventListener("input", () => {
        const valor = Number(input.value) || 1;
        const cantidadNormalizada = Math.max(1, Math.floor(valor));
        input.value = String(cantidadNormalizada);
      });
    });

    // Inicializar botones de información
    productosGrid?.querySelectorAll(".producto-info-button").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = btn.getAttribute("data-producto-id");
        if (!id) return;
        const producto = productos.find((item) => item.id === id);
        if (!producto) return;
        
        // Esperar a que el modal esté disponible si es necesario
        if (window.abrirModalProducto) {
          window.abrirModalProducto(producto);
        } else {
          // Esperar un poco y reintentar
          setTimeout(() => {
            if (window.abrirModalProducto) {
              window.abrirModalProducto(producto);
            }
          }, 200);
        }
      });
    });

    // Inicializar botones de agregar al carrito
    productosGrid?.querySelectorAll(".btn-agregar-carrito").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-producto-id");
        const producto = productos.find((item) => item.id === id);
        if (!producto) return;

        const card = btn.closest(".producto-card");
        const cantidadInput = card?.querySelector(".cantidad-input");
        const cantidad = Math.max(1, Math.floor(Number(cantidadInput?.value) || 1));

        const ejecutarAgregado = (manager) => {
          manager?.addItem(
            {
              id: producto.id,
              nombre: producto.nombre ?? "Producto sin nombre",
              imagen: producto.imagen ?? null,
            },
            cantidad,
          );
        };

        const cartManager = window.cartManager;
        if (cartManager) {
          ejecutarAgregado(cartManager);
        } else {
          document.addEventListener(
            "cart-ready",
            () => {
              ejecutarAgregado(window.cartManager ?? null);
            },
            { once: true },
          );
        }
      });
    });

    const PAGE_SIZE = 12;
    let paginaActual = 0;

    function leerFiltros() {
      return {
        termino: (busquedaInput?.value || "").trim().toLowerCase(),
        catsChecked: valoresCheckbox("filtro-categoria"),
        marcasChecked: valoresCheckbox("filtro-marca").map((m) =>
          m.trim().toUpperCase(),
        ),
        modelosChecked: valoresCheckbox("filtro-modelo").map((m) =>
          m.trim().toLowerCase(),
        ),
      };
    }

    function cardMatchFiltros(card, f) {
      const nombre =
        card.querySelector(".producto-nombre")?.textContent?.toLowerCase() ||
        "";
      const descripcion =
        card.querySelector(".producto-descripcion")?.textContent?.toLowerCase() ||
        "";
      const idCard = (card.getAttribute("data-producto-id") || "").toLowerCase();
      const modelos = (card.dataset.modelos || "")
        .split(",")
        .map((m) => m.trim().toLowerCase())
        .filter(Boolean);
      const marcas = (card.dataset.marcas || "")
        .split(",")
        .map((m) => m.trim().toUpperCase())
        .filter(Boolean);
      const categorias = (card.dataset.categorias || "")
        .split(",")
        .map((c) => c.trim())
        .filter(Boolean);

      const coincideBusqueda =
        !f.termino ||
        nombre.includes(f.termino) ||
        descripcion.includes(f.termino) ||
        idCard.includes(f.termino);
      const coincideModelo =
        f.modelosChecked.length === 0 ||
        f.modelosChecked.some((m) => modelos.includes(m));
      const coincideMarca =
        f.marcasChecked.length === 0 ||
        f.marcasChecked.some((m) => marcas.includes(m));
      const coincideCat =
        f.catsChecked.length === 0 ||
        f.catsChecked.some((c) => categorias.includes(c));

      return (
        coincideBusqueda &&
        coincideModelo &&
        coincideMarca &&
        coincideCat
      );
    }

    function aplicarOrdenTarjetas() {
      if (!productosGrid) return;
      const ordenEl = document.getElementById("ordenar");
      const sel = ordenEl && "value" in ordenEl ? ordenEl.value : "nombre-asc";
      const cards = Array.from(
        productosGrid.querySelectorAll(".producto-card"),
      );
      cards.sort((a, b) => {
        const na = a.querySelector(".producto-nombre")?.textContent || "";
        const nb = b.querySelector(".producto-nombre")?.textContent || "";
        return sel === "nombre-desc"
          ? nb.localeCompare(na, "es")
          : na.localeCompare(nb, "es");
      });
      cards.forEach((c) => productosGrid.appendChild(c));
    }

    function renderPaginacion(totalPaginas, totalCoincidentes) {
      if (!paginacionCatalogo) return;
      if (totalCoincidentes === 0 || totalPaginas <= 1) {
        paginacionCatalogo.classList.add("hidden");
        paginacionCatalogo.innerHTML = "";
        return;
      }
      paginacionCatalogo.classList.remove("hidden");
      const btnBase =
        "inline-flex min-h-8 min-w-8 touch-manipulation items-center justify-center rounded-md border border-gray-200 bg-white px-1.5 text-xs font-normal text-gray-700 transition hover:border-secondary hover:text-secondary disabled:cursor-not-allowed disabled:opacity-40 sm:min-h-9 sm:min-w-9 sm:px-2 sm:text-sm";
      const btnAct =
        "border-secondary bg-secondary text-white hover:bg-secondary-dark hover:text-white";
      const prevDis = paginaActual <= 0;
      const nextDis = paginaActual >= totalPaginas - 1;
      let html = "";
      html += `<button type="button" class="${btnBase}" data-page-action="prev" ${prevDis ? "disabled" : ""} aria-label="Página anterior">«</button>`;

      const maxBtns = 7;
      let start = Math.max(0, paginaActual - Math.floor(maxBtns / 2));
      let end = Math.min(totalPaginas, start + maxBtns);
      if (end - start < maxBtns) start = Math.max(0, end - maxBtns);
      for (let i = start; i < end; i++) {
        const active = i === paginaActual ? ` ${btnAct}` : "";
        const ac = i === paginaActual ? ' aria-current="page"' : "";
        html += `<button type="button" class="${btnBase}${active}" data-page="${i}" aria-label="Página ${i + 1}"${ac}>${i + 1}</button>`;
      }
      html += `<button type="button" class="${btnBase}" data-page-action="next" ${nextDis ? "disabled" : ""} aria-label="Página siguiente">»</button>`;
      paginacionCatalogo.innerHTML = html;
    }

    function syncVistaCatalogo(opts) {
      const resetPage = opts && opts.resetPage;
      if (!productosGrid || !catalogoResultadosResumen) return;
      if (resetPage) paginaActual = 0;

      const f = leerFiltros();
      const allCards = Array.from(
        productosGrid.querySelectorAll(".producto-card"),
      );
      const coincidentes = allCards.filter((c) => cardMatchFiltros(c, f));
      const total = coincidentes.length;
      const totalPaginas = total === 0 ? 1 : Math.ceil(total / PAGE_SIZE);

      if (paginaActual >= totalPaginas) {
        paginaActual = Math.max(0, totalPaginas - 1);
      }

      const start = paginaActual * PAGE_SIZE;
      const enPagina = new Set(coincidentes.slice(start, start + PAGE_SIZE));

      allCards.forEach((card) => {
        if (!cardMatchFiltros(card, f)) {
          card.style.display = "none";
          return;
        }
        card.style.display = enPagina.has(card) ? "" : "none";
      });

      if (total === 0) {
        catalogoResultadosResumen.textContent = "Sin resultados";
      } else {
        const desde = start + 1;
        const hasta = Math.min(start + PAGE_SIZE, total);
        catalogoResultadosResumen.textContent = `Mostrando ${desde}–${hasta} de ${total} resultados`;
      }

      renderPaginacion(totalPaginas, total);
    }

    function filtrar() {
      syncVistaCatalogo({ resetPage: true });
    }

    function irAPagina(n) {
      paginaActual = Math.max(0, n);
      syncVistaCatalogo({ resetPage: false });
    }

    paginacionCatalogo?.addEventListener("click", (e) => {
      const t = e.target;
      if (!(t instanceof Element)) return;
      const prev = t.closest("[data-page-action='prev']");
      const next = t.closest("[data-page-action='next']");
      const pageBtn = t.closest("[data-page]");
      if (prev && !prev.hasAttribute("disabled")) {
        irAPagina(paginaActual - 1);
      } else if (next && !next.hasAttribute("disabled")) {
        irAPagina(paginaActual + 1);
      } else if (pageBtn && !pageBtn.hasAttribute("data-page-action")) {
        const p = parseInt(pageBtn.getAttribute("data-page") || "", 10);
        if (!Number.isNaN(p)) irAPagina(p);
      }
    });

    document.getElementById("ordenar")?.addEventListener("change", () => {
      aplicarOrdenTarjetas();
      syncVistaCatalogo({ resetPage: true });
    });

    const limpiar = () => {
      if (busquedaInput) busquedaInput.value = "";
      document.querySelectorAll(".filtro-checkbox").forEach((el) => {
        if (el instanceof HTMLInputElement) el.checked = false;
      });
      filtrar();
    };

    btnLimpiar?.addEventListener("click", limpiar);
    busquedaInput?.addEventListener("input", filtrar);
    filtrosAside?.addEventListener("change", (e) => {
      const t = e.target;
      if (
        t instanceof HTMLInputElement &&
        t.classList.contains("filtro-checkbox")
      )
        filtrar();
    });

    aplicarOrdenTarjetas();
    syncVistaCatalogo({ resetPage: true });
  });
</script>
